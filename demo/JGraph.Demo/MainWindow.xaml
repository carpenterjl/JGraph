<Window x:Class="JGraph.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:jg="clr-namespace:JGraph.Controls;assembly=JGraph.Controls"
        Title="JGraph Demo Gallery" Height="680" Width="1040">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <TextBlock Text="Theme:" VerticalAlignment="Center" Margin="4,0" />
            <ComboBox x:Name="ThemeSelector" Width="140" DisplayMemberPath="Name"
                      SelectionChanged="OnThemeChanged" />
        </ToolBar>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox x:Name="ExampleList" Grid.Column="0"
                     DisplayMemberPath="Name"
                     SelectionChanged="OnExampleChanged"
                     Margin="4" />

            <Border Grid.Column="1" Margin="4" BorderBrush="#CCC" BorderThickness="1">
                <jg:FigureControl x:Name="Figure" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
