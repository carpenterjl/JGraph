<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>JGraph.Demo</RootNamespace>
    <AssemblyName>JGraph.Demo</AssemblyName>
    <Description>Demo gallery for JGraph exercising both the object-oriented and Matlab-like APIs.</Description>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Assets\sample-measurement.csv" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
