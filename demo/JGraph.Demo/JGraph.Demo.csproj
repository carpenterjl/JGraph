    <ProjectReference Include="..\..\src\JGraph.Data\JGraph.Data.csproj" />
    <ProjectReference Include="..\..\src\JGraph.Math\JGraph.Math.csproj" />
    <ProjectReference Include="..\..\src\JGraph.Objects\JGraph.Objects.csproj" />
    <ProjectReference Include="..\..\src\JGraph.Interaction\JGraph.Interaction.csproj" />
    <ProjectReference Include="..\..\src\JGraph.Api\JGraph.Api.csproj" />
    <ProjectReference Include="..\..\src\JGraph.Controls\JGraph.Controls.csproj" />
    <ProjectReference Include="..\..\src\JGraph.Plugins\JGraph.Plugins.csproj" />
  </ItemGroup>

</Project>
