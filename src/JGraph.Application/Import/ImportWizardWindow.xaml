<Window x:Class="JGraph.Application.Import.ImportWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Data" Height="540" Width="780"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <DockPanel Margin="12">
        <!-- Footer buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Back" Width="80" Margin="4,0" Command="{Binding BackCommand}" />
            <Button Content="Next" Width="80" Margin="4,0" Command="{Binding NextCommand}"
                    Visibility="{Binding IsPage1, Converter={StaticResource BoolToVisibility}}" />
            <Button Content="Import" Width="80" Margin="4,0" Command="{Binding ImportCommand}" IsDefault="True"
                    Visibility="{Binding IsPage2, Converter={StaticResource BoolToVisibility}}" />
            <Button Content="Cancel" Width="80" Margin="4,0" Command="{Binding CancelCommand}" IsCancel="True" />
        </StackPanel>

        <Grid>
            <!-- Page 1: Source & preview -->
            <Grid Visibility="{Binding IsPage1, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BrowseButton" Content="Browse…" Width="90" Click="OnBrowse" />
                    <Button x:Name="PasteButton" Content="Paste from Clipboard" Width="150" Margin="8,0,0,0" Click="OnPaste" />
                    <TextBlock Text="{Binding FilePathDisplay}" VerticalAlignment="Center" Margin="12,0,0,0"
                               TextTrimming="CharacterEllipsis" MaxWidth="380" />
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8"
                            Visibility="{Binding ShowSheetSelector, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Worksheet:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="160" ItemsSource="{Binding SheetNames}" SelectedItem="{Binding SelectedSheet, Mode=TwoWay}" />
                </StackPanel>

                <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                    <TextBlock Text="Delimiter:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="110" Margin="0,0,12,0" ItemsSource="{Binding DelimiterChoices}"
                              SelectedItem="{Binding SelectedDelimiter, Mode=TwoWay}" />
                    <TextBlock Text="Header:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="80" Margin="0,0,12,0" ItemsSource="{Binding HeaderChoices}"
                              SelectedItem="{Binding SelectedHeader, Mode=TwoWay}" />
                    <TextBlock Text="Decimal:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="100" Margin="0,0,12,0" ItemsSource="{Binding DecimalChoices}"
                              SelectedItem="{Binding SelectedDecimal, Mode=TwoWay}" />
                    <TextBlock Text="Skip rows:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="50" Text="{Binding SkipRows, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                </WrapPanel>

                <ListView x:Name="PreviewList" Grid.Row="3" />

                <StackPanel Grid.Row="4" Margin="0,8,0,0">
                    <TextBlock Text="{Binding Error}" Foreground="#C0392B" TextWrapping="Wrap"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />
                    <TextBlock Text="{Binding Warnings}" Foreground="#B9770E" TextWrapping="Wrap"
                               Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
            </Grid>

            <!-- Page 2: Columns & plot -->
            <Grid Visibility="{Binding IsPage2, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="X column" FontWeight="Bold" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding XChoices}" SelectedItem="{Binding SelectedX, Mode=TwoWay}" Margin="0,0,0,12" />

                    <TextBlock Text="Y columns" FontWeight="Bold" Margin="0,0,0,4" />
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" Height="180">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding YColumns}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="4,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Plot type" FontWeight="Bold" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding PlotKinds}" SelectedItem="{Binding SelectedPlotKind, Mode=TwoWay}" Margin="0,0,0,12" />

                    <StackPanel Visibility="{Binding ShowErrorColumn, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
                        <TextBlock Text="Error column" FontWeight="Bold" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding ErrorChoices}" SelectedItem="{Binding SelectedError, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Visibility="{Binding ShowHistogramBins, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,12">
                        <TextBlock Text="Bins:" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Width="60" Text="{Binding HistogramBins, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>

                    <TextBlock Text="Target" FontWeight="Bold" Margin="0,0,0,4" />
                    <RadioButton GroupName="Target" Content="New figure" IsChecked="{Binding IsNewFigure, Mode=TwoWay}" Margin="0,2" />
                    <RadioButton GroupName="Target" Content="Current axes (append)" IsChecked="{Binding IsCurrentAxes, Mode=TwoWay}" Margin="0,2" />
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
