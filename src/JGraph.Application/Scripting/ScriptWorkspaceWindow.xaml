<Window x:Class="JGraph.Application.Scripting.ScriptWorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="https://github.com/Dirkster99/AvalonDock"
        xmlns:controls="clr-namespace:JGraph.Controls.Scripting;assembly=JGraph.Controls"
        Title="JGraph Scripting Workspace" Width="1180" Height="760"
        PreviewKeyDown="OnPreviewKeyDown">
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="6,4"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <StackPanel Orientation="Horizontal">
                <Button Content="Open Workspace…" Padding="10,2" Margin="0,0,2,0"
                        Click="OnOpenWorkspaceClick" ToolTip="Open a folder of scripts and data files" />
                <Button Content="New Script" Padding="10,2" Margin="2,0"
                        Click="OnNewScriptClick" ToolTip="Create a new untitled JGS script" />
                <Button Content="Open File…" Padding="10,2" Margin="2,0"
                        Click="OnOpenFileClick" ToolTip="Open a script file" />
                <Button x:Name="SaveButton" Content="Save" Padding="10,2" Margin="2,0"
                        Click="OnSaveClick" ToolTip="Save the active script (Ctrl+S)" />
                <Separator Margin="8,0" />
                <Button x:Name="RunButton" Content="▶ Run (F5)" Padding="12,2" Margin="2,0"
                        Click="OnRunClick" ToolTip="Run the active script; continues when paused (F5)" />
                <Button x:Name="PauseButton" Content="⏸ Pause" Padding="10,2" Margin="2,0"
                        IsEnabled="False" Click="OnPauseClick"
                        ToolTip="Pause the running JGS script at its next statement" />
                <Button x:Name="StopButton" Content="■ Stop" Padding="12,2" Margin="2,0"
                        IsEnabled="False" Click="OnStopClick"
                        ToolTip="Stop the running script (Shift+F5)" />
                <Separator Margin="8,0" />
                <Button x:Name="StepOverButton" Content="Step Over (F10)" Padding="8,2" Margin="2,0"
                        IsEnabled="False" Click="OnStepOverClick"
                        ToolTip="Execute the paused statement, running calls to completion (F10)" />
                <Button x:Name="StepInButton" Content="Step In (F11)" Padding="8,2" Margin="2,0"
                        IsEnabled="False" Click="OnStepInClick"
                        ToolTip="Execute the paused statement, entering functions (F11)" />
                <Button x:Name="StepOutButton" Content="Step Out" Padding="8,2" Margin="2,0"
                        IsEnabled="False" Click="OnStepOutClick"
                        ToolTip="Run until the current function returns (Shift+F11)" />
                <Separator Margin="8,0" />
                <Menu Background="Transparent" VerticalAlignment="Center">
                    <MenuItem Header="View" Padding="8,2"
                              ToolTip="Show a hidden panel">
                        <MenuItem Header="Files" Tag="files" Click="OnViewPaneClick" />
                        <MenuItem Header="Console" Tag="console" Click="OnViewPaneClick" />
                        <MenuItem Header="Variables" Tag="variables" Click="OnViewPaneClick" />
                        <MenuItem Header="Call Stack" Tag="callstack" Click="OnViewPaneClick" />
                        <MenuItem Header="Data Viewer" Tag="dataviewer" Click="OnViewPaneClick" />
                    </MenuItem>
                </Menu>
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" />
            </StatusBarItem>
        </StatusBar>

        <dock:DockingManager x:Name="DockManager">
            <dock:LayoutRoot>
                <dock:LayoutPanel Orientation="Horizontal">
                    <dock:LayoutAnchorablePane DockWidth="230">
                        <dock:LayoutAnchorable Title="Files" ContentId="files" CanClose="False">
                            <DockPanel x:Name="FilesPanel">
                                <DockPanel DockPanel.Dock="Top" Margin="2">
                                    <Button x:Name="UpFolderButton" DockPanel.Dock="Left" Content="↑"
                                            Width="24" Margin="0,0,2,0" Click="OnUpFolderClick"
                                            ToolTip="Go to the parent folder" />
                                    <TextBox x:Name="AddressBox" VerticalContentAlignment="Center"
                                             KeyDown="OnAddressBoxKeyDown"
                                             ToolTip="Current workspace folder — type a path and press Enter" />
                                </DockPanel>
                                <TreeView x:Name="FilesTree" BorderThickness="0"
                                          MouseDoubleClick="OnFilesTreeDoubleClick" />
                            </DockPanel>
                        </dock:LayoutAnchorable>
                    </dock:LayoutAnchorablePane>

                    <dock:LayoutPanel Orientation="Vertical">
                        <dock:LayoutDocumentPane x:Name="DocumentPane" />
                        <dock:LayoutAnchorablePane DockHeight="170">
                            <dock:LayoutAnchorable Title="Console" ContentId="console" CanClose="False">
                                <TextBox x:Name="ConsoleBox" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                         FontFamily="Consolas" FontSize="12" Padding="4,2"
                                         TextWrapping="NoWrap" BorderThickness="0"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto" />
                            </dock:LayoutAnchorable>
                            <dock:LayoutAnchorable Title="Data Viewer" ContentId="dataviewer" CanClose="False">
                                <controls:DataGridTableControl x:Name="DataViewer" />
                            </dock:LayoutAnchorable>
                        </dock:LayoutAnchorablePane>
                    </dock:LayoutPanel>

                    <dock:LayoutPanel Orientation="Vertical" DockWidth="290">
                        <dock:LayoutAnchorablePane>
                            <dock:LayoutAnchorable Title="Variables" ContentId="variables" CanClose="False">
                                <ListView x:Name="VariablesList" BorderThickness="0"
                                          MouseDoubleClick="OnVariablesDoubleClick"
                                          ToolTip="Double-click an array or table to open it in the Data Viewer">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Name" Width="90"
                                                            DisplayMemberBinding="{Binding Name}" />
                                            <GridViewColumn Header="Type" Width="70"
                                                            DisplayMemberBinding="{Binding Type}" />
                                            <GridViewColumn Header="Value" Width="120"
                                                            DisplayMemberBinding="{Binding DisplayValue}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </dock:LayoutAnchorable>
                        </dock:LayoutAnchorablePane>
                        <dock:LayoutAnchorablePane DockHeight="180">
                            <dock:LayoutAnchorable Title="Call Stack" ContentId="callstack" CanClose="False">
                                <ListView x:Name="CallStackList" BorderThickness="0">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Function" Width="110"
                                                            DisplayMemberBinding="{Binding FunctionName}" />
                                            <GridViewColumn Header="Line" Width="45"
                                                            DisplayMemberBinding="{Binding Line}" />
                                            <GridViewColumn Header="File" Width="120"
                                                            DisplayMemberBinding="{Binding SourceId}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </dock:LayoutAnchorable>
                        </dock:LayoutAnchorablePane>
                    </dock:LayoutPanel>
                </dock:LayoutPanel>
            </dock:LayoutRoot>
        </dock:DockingManager>
    </DockPanel>
</Window>
