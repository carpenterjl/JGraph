<UserControl x:Class="JGraph.Controls.Browser.PlotBrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="8,6" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <TextBlock FontWeight="SemiBold" Text="Plot Browser" />
        </Border>

        <TreeView x:Name="Tree" BorderThickness="0" ContextMenuOpening="OnContextMenuOpening">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="0,1">
                        <CheckBox IsChecked="{Binding IsVisibleChecked}" Margin="0,0,5,0"
                                  VerticalAlignment="Center"
                                  Visibility="{Binding ShowVisibilityToggle, Converter={StaticResource BoolToVisibility}}"
                                  ToolTip="Visible" />
                        <TextBlock Text="{Binding Header}" VerticalAlignment="Center" />
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="DeleteMenuItem" Header="Delete" Click="OnDeleteClick" />
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>
    </DockPanel>
</UserControl>
