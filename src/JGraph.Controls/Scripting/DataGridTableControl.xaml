<UserControl x:Class="JGraph.Controls.Scripting.DataGridTableControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="4,2" LastChildFill="False">
            <TextBlock x:Name="TitleText" DockPanel.Dock="Left" VerticalAlignment="Center" FontWeight="SemiBold" />
            <Button x:Name="NextPageButton" DockPanel.Dock="Right" Content="▶" Width="24" Margin="2,0,0,0"
                    ToolTip="Next page" Click="OnNextPageClick" />
            <Button x:Name="PrevPageButton" DockPanel.Dock="Right" Content="◀" Width="24" Margin="8,0,0,0"
                    ToolTip="Previous page" Click="OnPrevPageClick" />
            <TextBlock x:Name="PageText" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="Gray" />
        </DockPanel>

        <DataGrid x:Name="Grid" Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserSortColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.VirtualizationMode="Recycling" />
    </Grid>
</UserControl>
