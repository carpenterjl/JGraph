<UserControl x:Class="JGraph.Controls.Inspector.PropertyInspectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:inspector="clr-namespace:JGraph.Controls.Inspector">
    <UserControl.Resources>
        <inspector:HexBrushConverter x:Key="HexBrush" />

        <Style x:Key="EditorTextBox" TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="2,1" />
            <EventSetter Event="KeyDown" Handler="OnEditorTextBoxKeyDown" />
        </Style>

        <DataTemplate x:Key="TextEditor">
            <TextBox Style="{StaticResource EditorTextBox}"
                     Text="{Binding Text, UpdateSourceTrigger=LostFocus}" />
        </DataTemplate>

        <DataTemplate x:Key="NumberEditor">
            <TextBox Style="{StaticResource EditorTextBox}"
                     Text="{Binding Text, UpdateSourceTrigger=LostFocus}" />
        </DataTemplate>

        <DataTemplate x:Key="ToggleEditor">
            <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center" />
        </DataTemplate>

        <DataTemplate x:Key="EnumEditor">
            <ComboBox ItemsSource="{Binding EnumValues}"
                      SelectedItem="{Binding SelectedEnumValue}"
                      Padding="4,1" />
        </DataTemplate>

        <DataTemplate x:Key="ColorSwatchAndHex">
            <DockPanel>
                <ComboBox DockPanel.Dock="Right" Width="17" Padding="0" Margin="2,0,0,0"
                          IsEnabled="{Binding IsColorEditorEnabled}"
                          ItemsSource="{Binding Source={x:Static inspector:PropertyRowViewModel.Palette}}"
                          SelectedItem="{Binding PaletteSelection}"
                          ToolTip="Pick from palette">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="12" Height="12" Margin="0,0,4,0"
                                        BorderBrush="Gray" BorderThickness="1"
                                        Background="{Binding Converter={StaticResource HexBrush}}" />
                                <TextBlock Text="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Border DockPanel.Dock="Left" Width="14" Height="14" Margin="0,0,4,0"
                        VerticalAlignment="Center" BorderBrush="Gray" BorderThickness="1"
                        Background="{Binding SwatchHex, Converter={StaticResource HexBrush}}" />
                <TextBox Style="{StaticResource EditorTextBox}"
                         IsEnabled="{Binding IsColorEditorEnabled}"
                         Text="{Binding Text, UpdateSourceTrigger=LostFocus}" />
            </DockPanel>
        </DataTemplate>

        <DataTemplate x:Key="ColorEditor">
            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource ColorSwatchAndHex}" />
        </DataTemplate>

        <DataTemplate x:Key="OptionalColorEditor">
            <DockPanel>
                <CheckBox DockPanel.Dock="Left" Content="Auto" Margin="0,0,6,0"
                          VerticalAlignment="Center"
                          IsChecked="{Binding IsAuto}" />
                <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource ColorSwatchAndHex}" />
            </DockPanel>
        </DataTemplate>

        <DataTemplate x:Key="RangeEditor">
            <TextBox Style="{StaticResource EditorTextBox}"
                     ToolTip="min, max"
                     Text="{Binding Text, UpdateSourceTrigger=LostFocus}" />
        </DataTemplate>

        <inspector:EditorTemplateSelector x:Key="EditorSelector"
                                          TextTemplate="{StaticResource TextEditor}"
                                          NumberTemplate="{StaticResource NumberEditor}"
                                          ToggleTemplate="{StaticResource ToggleEditor}"
                                          EnumTemplate="{StaticResource EnumEditor}"
                                          ColorTemplate="{StaticResource ColorEditor}"
                                          OptionalColorTemplate="{StaticResource OptionalColorEditor}"
                                          RangeTemplate="{StaticResource RangeEditor}" />
    </UserControl.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="8,6" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <StackPanel>
                <TextBlock x:Name="HeaderType" FontWeight="SemiBold" Text="Properties" />
                <TextBlock x:Name="HeaderName" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <TextBlock x:Name="EmptyHint" DockPanel.Dock="Top" Margin="8,10"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   TextWrapping="Wrap"
                   Text="Select an object in the figure (Edit mode) or the plot browser to edit its properties." />

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="Rows" Grid.IsSharedSizeScope="True" Focusable="False">
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                        Padding="6,3" Margin="0,4,0,1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ItemsControl.GroupStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="6,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Names" MinWidth="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       ToolTip="{Binding DisplayName}" />
                            <ContentPresenter Grid.Column="1" Content="{Binding}"
                                              ContentTemplateSelector="{StaticResource EditorSelector}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
